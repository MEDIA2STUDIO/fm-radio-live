<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin Dashboard - FM Radio Live</title>
  <link rel="stylesheet" href="/css/style.css">
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
</head>
<body class="admin-page">
  <nav class="navbar admin-navbar">
    <div class="nav-brand">
      <i class="fas fa-shield-alt"></i>
      <span>Admin Dashboard</span>
    </div>
    <div class="nav-links">
      <a href="/" class="nav-link">Home</a>
      <button onclick="logout()" class="btn btn-secondary btn-sm">Logout</button>
    </div>
  </nav>

  <main class="admin-container">
    <div class="admin-sidebar">
      <div class="sidebar-menu">
        <a href="#stats" class="menu-item active" onclick="showSection('stats')">
          <i class="fas fa-chart-bar"></i> Statistics
        </a>
        <a href="#users" class="menu-item" onclick="showSection('users')">
          <i class="fas fa-users"></i> Users
        </a>
        <a href="#create-user" class="menu-item" onclick="showSection('create-user')">
          <i class="fas fa-user-plus"></i> Create User
        </a>
        <a href="#live" class="menu-item" onclick="showSection('live')">
          <i class="fas fa-broadcast-tower"></i> Live Now
        </a>
      </div>
    </div>

    <div class="admin-content">
      <!-- Stats Section -->
      <section id="stats" class="admin-section active">
        <h2><i class="fas fa-chart-bar"></i> Platform Statistics</h2>
        <div class="stats-grid">
          <div class="stat-card">
            <i class="fas fa-users"></i>
            <h3 id="totalUsers">0</h3>
            <p>Total Users</p>
          </div>
          <div class="stat-card">
            <i class="fas fa-microphone"></i>
            <h3 id="totalBroadcasters">0</h3>
            <p>Broadcasters</p>
          </div>
          <div class="stat-card">
            <i class="fas fa-circle pulse-dot"></i>
            <h3 id="activeBroadcasts">0</h3>
            <p>Live Now</p>
          </div>
          <div class="stat-card">
            <i class="fas fa-broadcast-tower"></i>
            <h3 id="totalBroadcasts">0</h3>
            <p>Total Broadcasts</p>
          </div>
        </div>
      </section>

      <!-- Users Section -->
      <section id="users" class="admin-section">
        <h2><i class="fas fa-users"></i> User Management</h2>
        <div class="table-container">
          <table id="usersTable" class="admin-table">
            <thead>
              <tr>
                <th>ID</th>
                <th>Username</th>
                <th>Email</th>
                <th>Display Name</th>
                <th>Location</th>
                <th>Role</th>
                <th>Status</th>
                <th>Live</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody id="usersTableBody">
            </tbody>
          </table>
        </div>
      </section>

      <!-- Create User Section -->
      <section id="create-user" class="admin-section">
        <h2><i class="fas fa-user-plus"></i> Create New User</h2>
        <form id="createUserForm" class="admin-form">
          <div class="form-row">
            <div class="form-group">
              <label>Username</label>
              <input type="text" id="newUsername" required placeholder="Username">
            </div>
            <div class="form-group">
              <label>Email</label>
              <input type="email" id="newEmail" required placeholder="Email">
            </div>
          </div>
          <div class="form-row">
            <div class="form-group">
              <label>Password</label>
              <input type="password" id="newPassword" required placeholder="Password" minlength="6">
            </div>
            <div class="form-group">
              <label>Display Name</label>
              <input type="text" id="newDisplayName" placeholder="Display Name">
            </div>
          </div>
          <div class="form-row">
            <div class="form-group">
              <label>Location</label>
              <input type="text" id="newLocation" placeholder="City/Location">
            </div>
            <div class="form-group">
              <label>Role</label>
              <select id="newRole">
                <option value="broadcaster">Broadcaster</option>
                <option value="listener">Listener</option>
              </select>
            </div>
          </div>
          <div id="create-error" class="error-message" style="display: none;"></div>
          <div id="create-success" class="success-message" style="display: none;"></div>
          <button type="submit" class="btn btn-primary">
            <i class="fas fa-user-plus"></i> Create User
          </button>
        </form>
      </section>

      <!-- Live Now Section -->
      <section id="live" class="admin-section">
        <h2><i class="fas fa-broadcast-tower"></i> Live Broadcasters</h2>
        <div id="liveList" class="live-list">
          <p class="loading">Loading...</p>
        </div>
      </section>
    </div>
  </main>

  <script src="/js/admin.js"></script>
</body>
</html>